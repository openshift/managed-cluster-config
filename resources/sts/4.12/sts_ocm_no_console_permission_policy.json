{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "iam:GetRole",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "iam:ResourceTag/red-hat-managed": "true",
          "iam:ResourceTag/rosa_role_type": "OCM"
        }
      }
    }
  ]
}
